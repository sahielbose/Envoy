# ============================================================
# Envoy environment
# Mock-first: the whole app runs with USE_MOCKS=true and NO keys.
# Real keys are wired only in Phase 20 (see docs/ENVOY_BUILD_PLAN.md).
# ============================================================

# Master switch. Keep true through Phases 1–19. Flip per-provider in Phase 20.
USE_MOCKS=true

# --- Core (needed once you run a real DB locally; mock mode uses fixtures) ---
DATABASE_URL=postgresql://envoy:envoy@localhost:5432/envoy
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Phase 20: Auth providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phase 20: LLM + AI ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Phase 20: Web research ---
EXA_API_KEY=
TAVILY_API_KEY=

# --- Phase 20: Job sources (Greenhouse/Lever/Ashby boards need no key) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Phase 20: Object storage (résumé files) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=envoy-resumes

# --- Phase 20: Background jobs ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Phase 20: Email (approved sends only) ---
RESEND_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
