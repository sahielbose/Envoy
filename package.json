{
  "name": "envoy",
  "version": "0.1.0",
  "private": true,
  "description": "Envoy — your AI job-search & career copilot (candidate-side functional clone of Perfectly's Parker).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "eval": "tsx evals/run.ts",
    "db:enable": "psql \"$DATABASE_URL\" -f prisma/sql/enable-pgvector.sql",
    "db:index": "psql \"$DATABASE_URL\" -f prisma/sql/index-vectors.sql",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:enable && npm run db:push && npm run db:index && npm run db:seed",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "postinstall": "prisma generate"
  },
  "//": "Versions are indicative; install/upgrade during Phase 1.",
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@prisma/client": "^6.0.0",
    "next-auth": "^5.0.0-beta.25",
    "inngest": "^3.22.0",
    "zod": "^3.23.8",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.4",
    "@vitejs/plugin-react": "^4.3.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^25.0.1",
    "@playwright/test": "^1.48.2",
    "@axe-core/playwright": "^4.10.0",
    "tsx": "^4.19.2"
  }
}
